# Cache-busting: HTML always fresh, assets cached by hash
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# JS/CSS files have content hashes in filenames — safe to cache long
/assets/*
  Cache-Control: public, max-age=31536000, immutable
